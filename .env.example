# --- Non-secret runtime configuration ---
# Secrets (stripe.webhook.secret, stripe.api.key, db.password) are NEVER set here.
# AWS
AWS_REGION=eu-west-1
SSM_PARAMETER_PREFIX=/stripe-payment-notifier/dev/

# SES — the sending identity MUST be verified in SES before use
NOTIFICATION_FROM_EMAIL=no-reply@example.com
DB_URL=jdbc:postgresql://localhost:5432/stripe_notifier
DB_USER=postgres
